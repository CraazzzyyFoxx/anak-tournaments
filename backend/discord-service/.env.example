# Discord Bot Environment Variables

# Logging
LOG_LEVEL=info

# Discord
DISCORD_TOKEN=your-discord-bot-token-here

# Parser Service
PARSER_URL=http://localhost:8002

# Auth Service (service-to-service)
AUTH_SERVICE_URL=http://localhost:8001
SERVICE_CLIENT_ID=discord-service
SERVICE_CLIENT_SECRET=your-discord-service-secret

# RabbitMQ (optional, enables parser-service -> discord-service commands)
# RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Database (shared with main app)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=anak_tournaments
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Proxy (optional)
# PROXY_IP=
# PROXY_PORT=
# PROXY_USERNAME=
# PROXY_PASSWORD=
