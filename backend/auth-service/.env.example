# Auth Service Environment Variables

# Application
PROJECT_NAME=Authentication Service
ENVIRONMENT=development
API_V1_STR=/api/v1

# Database (shared with main app)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=anak_tournaments
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-min-32-chars-long-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Service-to-service auth (client credentials)
# JSON examples:
# SERVICE_CLIENTS={"discord-service":"secret","parser-service":"secret"}
# SERVICE_SCOPES={"discord-service":["parser:logs"],"parser-service":[]}
SERVICE_CLIENTS={"discord-service":"your-discord-service-secret"}
SERVICE_SCOPES={"discord-service":["parser:logs"]}
SERVICE_ACCESS_TOKEN_EXPIRE_MINUTES=5
SERVICE_TOKEN_ISSUER=auth-service
SERVICE_TOKEN_AUDIENCE=internal

# Service
HOST=0.0.0.0
PORT=8001
DEBUG=True

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Discord OAuth
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# Twitch OAuth
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret

# Battle.net OAuth
BATTLENET_CLIENT_ID=your-battlenet-client-id
BATTLENET_CLIENT_SECRET=your-battlenet-client-secret
# Supported values: eu, us, kr, cn
BATTLENET_REGION=eu

# Shared frontend OAuth callback for all providers
OAUTH_REDIRECT=http://localhost:3000/auth/callback

OAUTH_STATE_EXPIRE_MINUTES=10
