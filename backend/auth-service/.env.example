# Auth Service Environment Variables

# Application
PROJECT_NAME=Authentication Service
ENVIRONMENT=development
API_V1_STR=/api/v1

# Database (shared with main app)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=anak_tournaments
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-min-32-chars-long-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Service
HOST=0.0.0.0
PORT=8001
DEBUG=True

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Discord OAuth
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
# IMPORTANT: This must point to the FRONTEND callback URL, not backend!
# Discord will redirect users here after authorization.
# The frontend callback then exchanges the code with the backend API.
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback
