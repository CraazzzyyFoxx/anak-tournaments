PROJECT_NAME="Anak Tournaments - Balancer Service"
VERSION="1.0.0"
DESCRIPTION="Tournament team balancing service using genetic algorithms"
ENVIRONMENT="development"  # development, production, staging
DEBUG=false


HOST="0.0.0.0"
PORT=8005


API_V1_STR="/api/v1"
DOCS_URL="/docs"
REDOC_URL="/redoc"
OPENAPI_URL="/openapi.json"


CORS_ORIGINS="http://localhost:3000,http://localhost:8000"
CORS_ALLOW_CREDENTIALS=true
# CORS_ALLOW_METHODS="*"
# CORS_ALLOW_HEADERS="*"


LOG_LEVEL="INFO"  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOGS_ROOT_PATH="./logs"


MAX_WORKERS=4
REQUEST_TIMEOUT=300

# ==========================================
# Balancing Algorithm Configuration
# ==========================================
# Note: These can be overridden per-request via API

# Genetic Algorithm Parameters
BALANCER_POPULATION_SIZE=200       # Population size (10-1000)
BALANCER_GENERATIONS=750           # Number of generations (10-5000)
BALANCER_ELITISM_RATE=0.2         # Elite preservation rate (0.0-1.0)
BALANCER_MUTATION_RATE=0.4        # Mutation probability (0.0-1.0)
BALANCER_MUTATION_STRENGTH=3      # Mutation operations per event (1-10)

# Cost Function Weights
BALANCER_MMR_DIFF_WEIGHT=3.0           # MMR balance between teams
BALANCER_DISCOMFORT_WEIGHT=0.25        # Role preference satisfaction
BALANCER_INTRA_TEAM_VAR_WEIGHT=0.8     # Team internal consistency
BALANCER_MAX_DISCOMFORT_WEIGHT=1.0     # Worst-case role assignment penalty

# Strategy Settings
BALANCER_USE_CAPTAINS=true        # Enable captain assignment

# Display Settings
BALANCER_CARDS_PER_ROW=4          # Team cards per row in console (1-10)
BALANCER_CARD_WIDTH=40            # Team card width in console (20-100)
