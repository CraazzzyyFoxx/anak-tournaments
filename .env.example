# Environment Configuration Template
# Copy this file to .env and fill in your values

# =============================================================================
# Core Settings
# =============================================================================
ENVIRONMENT=development
PROJECT_URL=http://localhost
APP_PORT=80
CORS_ORIGINS=http://localhost,http://localhost:3000

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=aqt_db
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://redis:6379

# =============================================================================
# RabbitMQ Configuration (Production)
# =============================================================================
RABBITMQ_URL=amqp://admin:secure_password@rabbitmq:5672
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=secure_password
# RABBITMQ_ERLANG_COOKIE=your_erlang_cookie_here

# =============================================================================
# Authentication & JWT
# =============================================================================
ACCESS_TOKEN_SECRET=your_access_token_secret_min_32_chars
REFRESH_TOKEN_SECRET=your_refresh_token_secret_min_32_chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ACCESS_TOKEN_SERVICE=your_service_token_here

# =============================================================================
# Superuser Configuration
# =============================================================================
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=your_admin_password

# =============================================================================
# External API - Challonge
# =============================================================================
CHALLONGE_API_KEY=your_challonge_api_key
CHALLONGE_USERNAME=your_challonge_username

# =============================================================================
# External API - Twitch
# =============================================================================
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret

# =============================================================================
# External API - Discord
# =============================================================================
DISCORD_TOKEN=your_discord_bot_token
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CHANNEL_ID=your_discord_channel_id
DISCORD_GUILD_ID=your_discord_guild_id
TOURNAMENT_ID=your_tournament_id

# =============================================================================
# S3 Storage Configuration
# =============================================================================
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key
S3_ENDPOINT_URL=https://s3.amazonaws.com
S3_BUCKET_NAME=your_bucket_name

# =============================================================================
# Proxy Configuration (Optional)
# =============================================================================
PROXY_IP=your_proxy_ip
PROXY_PORT=your_proxy_port
PROXY_USERNAME=your_proxy_username
PROXY_PASSWORD=your_proxy_password

# =============================================================================
# Service URLs (Internal)
# =============================================================================
API_URL=http://backend:8000
PARSER_URL=http://parser:8081

# =============================================================================
# Frontend Configuration
# =============================================================================
NEXT_API_URL=http://backend:8000
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_CACHE_POLICY=no-cache

# =============================================================================
# Logging & Monitoring
# =============================================================================
LOG_LEVEL=INFO
DEBUG=false

# =============================================================================
# Notes
# =============================================================================
# 1. Never commit the .env file to version control
# 2. Generate secure random strings for secrets:
#    - Linux/Mac: openssl rand -hex 32
#    - Windows PowerShell: -join ((48..57) + (65..90) + (97..122) | Get-Random -Count 32 | % {[char]$_})
# 3. For production, use strong passwords and rotate secrets regularly
# 4. Use host.docker.internal for local database on host machine
# 5. Use service names (redis, rabbitmq, etc.) for container-to-container communication
