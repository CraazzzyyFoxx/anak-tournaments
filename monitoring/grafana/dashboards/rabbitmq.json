{
  "title": "RabbitMQ",
  "uid": "rabbitmq",
  "tags": ["rabbitmq", "messaging"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Broker Status",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ]
        }
      },
      "targets": [{ "expr": "rabbitmq_up", "legendFormat": "Status" }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Messages",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rabbitmq_queue_messages{queue!~\".*\\.dlq\"})", "legendFormat": "Total" }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total DLQ Messages",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [{ "expr": "sum(rabbitmq_queue_messages{queue=~\".*\\.dlq\"})", "legendFormat": "DLQ" }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total Consumers",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rabbitmq_queue_consumers{queue!~\".*\\.dlq\"})", "legendFormat": "Consumers" }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Queue Depth (main queues)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "expr": "rabbitmq_queue_messages{queue!~\".*\\.dlq\"}", "legendFormat": "{{ queue }}" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Dead Letter Queue Depth",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      },
      "targets": [
        { "expr": "rabbitmq_queue_messages{queue=~\".*\\.dlq\"}", "legendFormat": "{{ queue }}" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Message Publish Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "expr": "rate(rabbitmq_queue_messages_published_total{queue!~\".*\\.dlq\"}[1m])", "legendFormat": "{{ queue }}" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Message Deliver Rate",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "expr": "rate(rabbitmq_queue_messages_delivered_total{queue!~\".*\\.dlq\"}[1m])", "legendFormat": "{{ queue }}" }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Consumers per Queue",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rabbitmq_queue_consumers{queue!~\".*\\.dlq\"}", "legendFormat": "{{ queue }}" }
      ]
    }
  ]
}
