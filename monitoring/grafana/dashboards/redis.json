{
  "title": "Redis",
  "uid": "redis",
  "tags": ["redis", "cache"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Redis Status",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ]
        }
      },
      "targets": [{ "expr": "redis_up", "legendFormat": "Status" }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Memory Used",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [{ "expr": "redis_memory_used_bytes", "legendFormat": "Used" }]
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Memory Usage %",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.75 }, { "color": "red", "value": 0.90 }] }
        }
      },
      "targets": [{ "expr": "redis_memory_used_bytes / redis_memory_max_bytes", "legendFormat": "Memory %" }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Connected Clients",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 100 }] }
        }
      },
      "targets": [{ "expr": "redis_connected_clients", "legendFormat": "Clients" }]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Evicted Keys (total)",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      },
      "targets": [{ "expr": "redis_evicted_keys_total", "legendFormat": "Evicted" }]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Memory Used vs Max",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        { "expr": "redis_memory_used_bytes", "legendFormat": "Used" },
        { "expr": "redis_memory_max_bytes", "legendFormat": "Max" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Commands / sec",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "rate(redis_commands_processed_total[1m])", "legendFormat": "Ops/s" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Keyspace Hit Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "targets": [
        {
          "expr": "rate(redis_keyspace_hits_total[1m]) / (rate(redis_keyspace_hits_total[1m]) + rate(redis_keyspace_misses_total[1m]))",
          "legendFormat": "Hit rate"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Key Evictions / min",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      },
      "targets": [
        { "expr": "increase(redis_evicted_keys_total[1m])", "legendFormat": "Evictions/min" }
      ]
    },
    {
      "id": 10,
      "type": "stat",
      "title": "DB3 Keys (API cache: fastapi:)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "redis_db_keys{db=\"db3\"}", "legendFormat": "Keys" }]
    },
    {
      "id": 11,
      "type": "stat",
      "title": "DB4 Keys (backend cache: backend:)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "redis_db_keys{db=\"db4\"}", "legendFormat": "Keys" }]
    }
  ]
}
